void setup()
{
  Serial.begin(9600);

  for(int pin=2; pin<=13; pin++)
  {
    pinMode(pin, OUTPUT);
  }
}

void loop()
{
  // Read Analog Inputs
  int sensor1 = analogRead(A0);
  int sensor2 = analogRead(A1);

  Serial.print("A0 = ");
  Serial.print(sensor1);

  Serial.print("   A1 = ");
  Serial.println(sensor2);

  // Turn ON all LEDs
  for(int pin=2; pin<=13; pin++)
  {
    digitalWrite(pin, HIGH);
    delay(100);
  }

  // Turn OFF all LEDs
  for(int pin=2; pin<=13; pin++)
  {
    digitalWrite(pin, LOW);
    delay(100);
  }

  // PWM Demonstration
  analogWrite(3, 128);
  analogWrite(5, 128);
  analogWrite(6, 128);
  analogWrite(9, 128);
  analogWrite(10,128);
  analogWrite(11,128);

  delay(1000);
}
